# TimescaleDB / Postgres connection string.
# Local dev with docker-compose.yml:
DATABASE_URL="postgresql://apex:apex@localhost:5433/apex_engine"

# Production (Timescale Cloud) — swap in the string from your service's
# "Connection info" page. SSL is auto-detected from this URL (sslmode=require
# or a non-localhost host); no other changes needed.
# DATABASE_URL="postgresql://tsdbadmin:PASSWORD@HOST.tsdb.cloud.timescale.com:PORT/tsdb?sslmode=require"

# Optional override if SSL auto-detection ever guesses wrong: "true" | "false"
# PGSSL=true

PORT=3000
